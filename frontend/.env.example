# VulnShop frontend — environment variables
#
# In Vite, any variable prefixed VITE_ is exposed to the client bundle at
# build time. Vercel reads .env.production automatically for `npm run build`,
# or set the variable in Project Settings → Environment Variables.

# Absolute URL of the deployed VulnShop backend (no trailing slash, no /api).
# Leave UNSET locally — the dev server uses Vite's /api proxy to localhost:8000.
VITE_API_URL=https://vulnshop-backend.up.railway.app
