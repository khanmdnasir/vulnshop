# VulnShop backend — environment variables
#
# Copy to .env locally, or set in Railway → Variables for the deployed instance.
# All values shown are the SAFE-FOR-LAB defaults — leaving them empty keeps the
# intentional vulnerabilities active.

# ---------- Server binding ----------
# Local default 127.0.0.1; Railway provides PORT and you should set HOST=0.0.0.0
HOST=127.0.0.1
PORT=8000

# ---------- A04 — JWT signing secret ----------
# Default "secret" keeps the offline-crack demo working. Override for a "fixed"
# version of the deploy if needed.
JWT_SECRET=secret

# ---------- A02 — CORS allow-list ----------
# Default "*" preserves the misconfiguration finding. To tighten (e.g. when
# fronting the Vercel app only), set a comma-separated origin list:
#   CORS_ORIGINS=https://vulnshop-frontend.vercel.app
CORS_ORIGINS=*

# ---------- Database ----------
# Path to the SQLite file. Ephemeral on Railway by default; re-seeded on every
# startup. Set to /data/shop.db if you attach a Railway Volume.
DB_PATH=shop.db
